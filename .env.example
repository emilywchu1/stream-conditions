# USGS NWIS — no API key required; placeholder for future auth
USGS_API_KEY=

# Open-Meteo — no key required for non-commercial use
OPEN_METEO_API_KEY=

# Comma-separated USGS site numbers to monitor (e.g. 12345678,87654321)
GAUGE_IDS=12345678

# Database path relative to project root
DB_PATH=data/stream_conditions.db

# FastAPI server
HOST=127.0.0.1
PORT=8000
